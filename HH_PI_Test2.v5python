{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nleft_motors_motor_a = Motor(Ports.PORT19, GearSetting.RATIO_18_1, False)\nleft_motors_motor_b = Motor(Ports.PORT20, GearSetting.RATIO_18_1, False)\nleft_motors = MotorGroup(left_motors_motor_a, left_motors_motor_b)\nright_motors_motor_a = Motor(Ports.PORT9, GearSetting.RATIO_18_1, True)\nright_motors_motor_b = Motor(Ports.PORT10, GearSetting.RATIO_18_1, True)\nright_motors = MotorGroup(right_motors_motor_a, right_motors_motor_b)\nmy_gps = Gps(Ports.PORT6, 0.00, 40.00, MM, 180)\nled_green = Led(brain.three_wire_port.a)\nled_yellow = Led(brain.three_wire_port.b)\nled_red = Led(brain.three_wire_port.c)\n\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n#endregion VEXcode Generated Robot Configuration\n\nangular_p_k = 15.0\nangular_p_i = 0\nlinear_p_k = 0.1\nlinear_p_i = 0\n\nlast_loc = (0,0)\nspeed_squared_arrival_threshold = 400\ndistance_squared_arrival_threshold = 600\nangular_integral = 0\nlinear_integral = 0\nangular_turn_only_threshold = math.pi/12\n\ncounter = 0\n\ndef when_started1():\n    global last_loc\n    global controller\n    controller = Controller()\n    brain.screen.set_cursor(2,2)\n    brain.screen.print(\"Hello, World!\")\n    led_red.on()\n    led_yellow.on()\n    led_green.on()\n    brain.screen.set_cursor(3,1)\n    controller.screen.set_cursor(4,1)\n    controller.screen.print(\"Calibrating...\")\n    my_gps.calibrate()\n    last_loc = (my_gps.x_position(MM), my_gps.y_position(MM))\n    controller.screen.set_cursor(4,1)\n    controller.screen.print(\"Calibrated.\")\n    led_red.off()\n    led_yellow.off()\n    led_green.off()\n\n\ndef prepare_for_turn_and_drive():\n    global angular_integral, linear_integral\n    angular_integral = 0\n    linear_integral = 0\n\ndef delta_heading_toward_target(desired_loc:Tuple[int])->float:\n    \"\"\"\n    finds the amount the robot needs to turn to point at the given (x,y)\n    :param desired_loc: the location (x,y) we want to turn towards\n    :return: -π < delta_heading < π or null, if location matches.\n    \"\"\"\n    current_loc = (my_gps.x_position(MM), my_gps.y_position(MM))\n    delta_loc = (desired_loc[0]-current_loc[0], desired_loc[1]-current_loc[1])\n    desired_heading = math.degrees(math.atan2(delta_loc[0], delta_loc[1]))\n    # controller.screen.set_cursor(1,1)\n    # controller.screen.print(\"dsrd: {}\".format(round(desired_heading,1)))\n        \n    current_heading = my_gps.heading()\n    # controller.screen.set_cursor(2,1)\n    # controller.screen.print(\"Actual: {}\".format(round(current_heading,1)))\n        \n    delta_heading = desired_heading-current_heading + 180\n    while delta_heading < 0:\n        delta_heading += 360\n    delta_heading %= 360\n    delta_heading -= 180\n    return math.radians(delta_heading)\n\ndef distance_squared_to_target(desired_loc:Tuple[int]) ->float:\n    \"\"\"\n    finds the square of the distance to the desired (x,y). You'll need to sqrt this for actual distance.\n    :param desired_loc: the location (x,y) we want to turn towards\n    :return: the square of the distance from the robot to the desired location\n    \"\"\"\n    current_loc = (my_gps.x_position(MM), my_gps.y_position(MM))\n    delta_loc = (current_loc[0]-desired_loc[0], current_loc[1]-desired_loc[1])\n    return math.pow(delta_loc[0],2) + math.pow(delta_loc[1],2)\n\ndef move_a_little_toward_loc(desired_loc:Tuple[int], speed_arrival_threshold, distance_arrival_threshold) -> bool:\n    global last_loc, angular_integral, linear_integral\n    global counter\n    counter +=1\n    current_loc = (my_gps.x_position(MM), my_gps.y_position(MM))\n    velocity = (current_loc[0]-last_loc[0], current_loc[1]-last_loc[1])\n    speed_squared = math.pow(velocity[0],2)+math.pow(velocity[1],2)\n    distance_squared = distance_squared_to_target(desired_loc)\n    if speed_squared < math.pow(speed_arrival_threshold,2) and \\\n       distance_squared < math.pow(distance_arrival_threshold,2):\n       left_motors.stop()\n       right_motors.stop()\n       return True\n    linear_error = math.sqrt(distance_squared)\n    speed = math.sqrt(speed_squared)\n    if counter %10 == 0:\n        controller.screen.clear_row(3)\n        controller.screen.set_cursor(3,1)\n        controller.screen.print(\"S:{:3.0f} D:{:3.0f}\".format(speed,linear_error) )\n    linear_integral += linear_error\n\n    delta_heading = delta_heading_toward_target(desired_loc)\n    # controller.screen.set_cursor(3,1)\n    # controller.screen.print(\"{}\".format(round(math.degrees(delta_heading),1)))\n    # controller.screen.set_cursor(3,8)\n    # if delta_heading < 0:\n    #     controller.screen.print(\"<-\")\n    # if delta_heading > 0:\n    #     controller.screen.print(\"->\")\n    angular_integral += delta_heading\n    desired_turn_velocity = max(min(angular_p_k * delta_heading + angular_p_i * angular_integral, 90),-90)\n    # controller.screen.print(round(desired_turn_velocity,1))\n    # if math.fabs(desired_turn_velocity) > 7:\n    #     drivetrain.set_turn_velocity(desired_turn_velocity, PERCENT)\n    #     drivetrain.turn(RIGHT)\n\n    desired_velocity = 0\n    if math.fabs(delta_heading) < angular_turn_only_threshold:\n        # controller.screen.set_cursor(3,1)\n        # controller.screen.print(\"distance: {:3.1f}\".format(linear_error))\n        desired_velocity = min(linear_p_k * linear_error + linear_p_i * linear_integral,90)\n    \n    left_motors.set_velocity(max(min(desired_velocity + desired_turn_velocity, 90), -90),PERCENT)\n    right_motors.set_velocity(max(min(desired_velocity - desired_turn_velocity, 90), -90),PERCENT)\n\n    if counter %10 == 0:\n        controller.screen.clear_row(1)\n        controller.screen.set_cursor(1,1)\n        controller.screen.print(\"dtv={:3.2f}%{}\".format(desired_turn_velocity,angular_integral))\n        controller.screen.clear_row(2)\n        controller.screen.set_cursor(2,1)\n        controller.screen.print(\"dv={:3.2f}%{}\".format(desired_velocity,linear_integral))\n\n    left_motors.spin(FORWARD)\n    right_motors.spin(FORWARD)\n\n    last_loc = current_loc\n    return False\n\ndef onauton_autonomous_0():\n    global myVariable\n    brain.screen.print(\"Start Auton.\")\n    # drivetrain.set_turn_velocity(85, PERCENT)\n    # corrections = 0\n    arrived = False\n    prepare_for_turn_and_drive()\n    target = (300.0, 900.0)\n    while not arrived:\n        # controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    prepare_for_turn_and_drive()\n    led_green.off()\n    led_yellow.on()\n    target = (1000.0, 0.0)\n    arrived = False\n    while not arrived:\n        controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    prepare_for_turn_and_drive()\n    led_yellow.off()\n    led_red.on()\n    target = (0.0, -750.0)\n    arrived = False\n    while not arrived:\n        controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    prepare_for_turn_and_drive()\n    led_green.on()\n    led_yellow.on()\n    led_red.off()\n    target = (-750.0, -750.0)\n    arrived = False\n    while not arrived:\n        controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    prepare_for_turn_and_drive()\n    led_yellow.off()\n    led_red.off()\n    target = (-750.0, 0.0)\n    arrived = False\n    while not arrived:\n        controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    prepare_for_turn_and_drive()\n    led_green.off()\n    led_red.on()\n    target = (-400.0, 750.0)\n    arrived = False\n    while not arrived:\n        controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    controller.screen.set_cursor(4,1)\n    controller.screen.print(\"Done.\")\n    led_green.on()\n    led_yellow.on()\n    led_red.on()\n\ndef ondriver_drivercontrol_0():\n    global myVariable\n    brain.screen.clear_screen()\n    brain.screen.print(\"Start DC\")\n    while True:\n        wait(5, MSEC)\n\n# create a function for handling the starting and stopping of all autonomous tasks\ndef vexcode_auton_function():\n    # Start the autonomous control tasks\n    auton_task_0 = Thread( onauton_autonomous_0 )\n    # wait for the driver control period to end\n    while( competition.is_autonomous() and competition.is_enabled() ):\n        # wait 10 milliseconds before checking again\n        wait( 10, MSEC )\n    # Stop the autonomous control tasks\n    auton_task_0.stop()\n\ndef vexcode_driver_function():\n    # Start the driver control tasks\n    driver_control_task_0 = Thread( ondriver_drivercontrol_0 )\n\n    # wait for the driver control period to end\n    while( competition.is_driver_control() and competition.is_enabled() ):\n        # wait 10 milliseconds before checking again\n        wait( 10, MSEC )\n    # Stop the driver control tasks\n    driver_control_task_0.stop()\n\n\n# register the competition functions\ncompetition = Competition( vexcode_driver_function, vexcode_auton_function )\n\nwhen_started1()\n","textLanguage":"python","robotConfig":[{"port":[19,20],"name":"left_motors","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","gear":"ratio18_1","motor_a_reversed":"false","motor_b_reversed":"false"},"triportSourcePort":22},{"port":[9,10],"name":"right_motors","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","gear":"ratio18_1","motor_a_reversed":"true","motor_b_reversed":"true"},"triportSourcePort":22},{"port":[6],"name":"my_gps","customName":true,"deviceType":"GPS","deviceClass":"gps","setting":{"xOffset":"0","xOffsetUnit":"mm","yOffset":"40","yOffsetUnit":"mm","thetaOffset":"180"},"triportSourcePort":22},{"port":[1],"name":"led_green","customName":true,"deviceType":"LED","deviceClass":"led","setting":{},"triportSourcePort":22},{"port":[2],"name":"led_yellow","customName":true,"deviceType":"LED","deviceClass":"led","setting":{},"triportSourcePort":22},{"port":[3],"name":"led_red","customName":true,"deviceType":"LED","deviceClass":"led","setting":{},"triportSourcePort":22}],"slot":0,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.65.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"target":"Physical"}