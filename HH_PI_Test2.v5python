{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nleft_motors_motor_a = Motor(Ports.PORT19, GearSetting.RATIO_18_1, False)\nleft_motors_motor_b = Motor(Ports.PORT20, GearSetting.RATIO_18_1, False)\nleft_motors = MotorGroup(left_motors_motor_a, left_motors_motor_b)\nright_motors_motor_a = Motor(Ports.PORT9, GearSetting.RATIO_18_1, True)\nright_motors_motor_b = Motor(Ports.PORT10, GearSetting.RATIO_18_1, True)\nright_motors = MotorGroup(right_motors_motor_a, right_motors_motor_b)\nmy_gps = Gps(Ports.PORT6, 0.00, 40.00, MM, 180)\nled_green = Led(brain.three_wire_port.a)\nled_yellow = Led(brain.three_wire_port.b)\nled_red = Led(brain.three_wire_port.c)\n\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n#endregion VEXcode Generated Robot Configuration\n\nangular_p_k = 15.0\nangular_p_i = 0\nlinear_p_k = 0.1\nlinear_p_i = 0\n\nlast_loc = (0,0)\nspeed_squared_arrival_threshold = 400\ndistance_squared_arrival_threshold = 600\nangular_integral = 0\nlinear_integral = 0\nangular_turn_only_threshold = math.pi/12\n\ncounter = 0\n\ndef when_started1():\n    global last_loc\n    global controller\n    controller = Controller()\n    led_red.on()\n    led_yellow.on()\n    led_green.on()\n    controller.screen.set_cursor(4,1)\n    controller.screen.print(\"Calibrating...\")\n    my_gps.calibrate()\n    last_loc = (my_gps.x_position(MM), my_gps.y_position(MM))\n    controller.screen.set_cursor(4,1)\n    controller.screen.print(\"Calibrated.\")\n    led_red.off()\n    led_yellow.off()\n    led_green.off()\n\n\ndef prepare_for_turn_and_drive():\n    global angular_integral, linear_integral\n    angular_integral = 0\n    linear_integral = 0\n\ndef delta_heading_toward_target(desired_loc:Tuple[int])->float:\n    \"\"\"\n    finds the amount the robot needs to turn to point at the given (x,y)\n    :param desired_loc: the location (x,y) we want to turn towards\n    :return: -π < delta_heading < π or null, if location matches.\n    \"\"\"\n    current_loc = (my_gps.x_position(MM), my_gps.y_position(MM))\n    delta_loc = (desired_loc[0]-current_loc[0], desired_loc[1]-current_loc[1])\n    \n    desired_heading = math.degrees(math.atan2(delta_loc[0], delta_loc[1]))\n    current_heading = my_gps.heading()\n        \n    delta_heading = desired_heading-current_heading + 180\n    while delta_heading < 0:\n        delta_heading += 360\n    delta_heading %= 360\n    delta_heading -= 180\n    return math.radians(delta_heading)\n\ndef distance_to_target(desired_loc:Tuple[int]) ->float:\n    \"\"\"\n    finds the square of the distance to the desired (x,y). You'll need to sqrt this for actual distance.\n    :param desired_loc: the location (x,y) we want to turn towards\n    :return: the square of the distance from the robot to the desired location\n    \"\"\"\n    current_loc = (my_gps.x_position(MM), my_gps.y_position(MM))\n    delta_loc = (current_loc[0]-desired_loc[0], current_loc[1]-desired_loc[1])\n    return math.sqrt(math.pow(delta_loc[0],2) + math.pow(delta_loc[1],2))\n\ndef move_a_little_toward_loc(desired_loc:Tuple[int], speed_arrival_threshold, distance_arrival_threshold) -> bool:\n    \"\"\"\n    determine how to turn and move a little bit towards the given desired location in the gps and indicate whether the robot has arrived.\n    :param desired_loc: the coordinates to head towards\n    :param speed_arrival_threshold: to say we have arrived, the speed of the robot must be less than this value.\n    :param distance_arrival_threshold: to say we have arrived, the distance from the robot to the target must be less than this value.\n    :return: whether we are at the deisred_loc and relatively slow moving, so that the arrival thresholds have been met.\n    \"\"\"\n    global last_loc, angular_integral, linear_integral\n    global counter\n    counter +=1\n\n    current_loc = (my_gps.x_position(MM), my_gps.y_position(MM))\n    velocity = (current_loc[0]-last_loc[0], current_loc[1]-last_loc[1])\n    speed = math.sqrt(math.pow(velocity[0],2)+math.pow(velocity[1],2))\n    linear_error = distance_to_target(desired_loc)\n\n    # Detect whether we have arrived at the desired_loc.\n    if speed < speed_arrival_threshold and linear_error < distance_arrival_threshold:\n       left_motors.stop()\n       right_motors.stop()\n       return True    \n    \n    # update integrals\n    linear_integral += linear_error\n    delta_heading = delta_heading_toward_target(desired_loc)\n    angular_integral += delta_heading\n\n    # calculate how fast to turn.\n    desired_turn_velocity = max(min(angular_p_k * delta_heading + angular_p_i * angular_integral, 90),-90)\n    \n    # calculate how fast to move.. if we are generally pointing in the right direction.\n    if math.fabs(delta_heading) < angular_turn_only_threshold:\n        desired_velocity = min(linear_p_k * linear_error + linear_p_i * linear_integral,90)\n    else:\n        desired_velocity = 0\n    \n    # set motors' velocities, based on desired turn velocity and desired velocity\n    left_motors.set_velocity(max(min(desired_velocity + desired_turn_velocity, 90), -90),PERCENT)\n    right_motors.set_velocity(max(min(desired_velocity - desired_turn_velocity, 90), -90),PERCENT)\n\n    # Display info every 10 iterations (to reduce flicker)\n    if counter %10 == 0:\n        controller.screen.clear_screen()\n        controller.screen.set_cursor(1,1)\n        controller.screen.print(\"dtv={:3.2f}%{}\".format(desired_turn_velocity,angular_integral))\n        controller.screen.set_cursor(2,1)\n        controller.screen.print(\"dv={:3.2f}%{}\".format(desired_velocity,linear_integral))\n        controller.screen.set_cursor(3,1)\n        controller.screen.print(\"S:{:3.0f} D:{:3.0f}\".format(speed,linear_error) )\n\n    # tell motors to move. (We'll always say forwards, but negative velocity will set it backwards.)\n    left_motors.spin(FORWARD)\n    right_motors.spin(FORWARD)\n\n    # update the \"last_loc\" for next iteration.\n    last_loc = current_loc\n\n    return False # we have not arrived yet.\n\ndef onauton_autonomous_0():\n    global myVariable\n    brain.screen.print(\"Start Auton.\")\n    # --------------------------  Go to waypoint 0\n    prepare_for_turn_and_drive()\n    target = (300.0, 900.0)\n    arrived = False\n    while not arrived:\n        controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    # ------------------------- arrived at 0\n    led_green.off()\n    led_yellow.on()\n    # -------------------------- Go to waypoint 1\n    prepare_for_turn_and_drive()\n    target = (1000.0, 0.0)\n    arrived = False\n    while not arrived:\n        controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    # ------------------------- arrived at 1\n    led_yellow.off()\n    led_red.on()\n    # -------------------------  Go to waypoint 2\n    prepare_for_turn_and_drive()\n    target = (0.0, -750.0)\n    arrived = False\n    while not arrived:\n        controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    # ------------------------- arrived at 2\n    led_green.on()\n    led_yellow.on()\n    led_red.off()\n    # ------------------------   Go to waypoint 3\n    prepare_for_turn_and_drive()\n    target = (-750.0, -750.0)\n    arrived = False\n    while not arrived:\n        controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    # ------------------------ arrived at 3\n    led_yellow.off()\n    led_red.off()\n    # -------------------------  Go to waypoint 4\n    prepare_for_turn_and_drive()\n    target = (-750.0, 0.0)\n    arrived = False\n    while not arrived:\n        controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    # -------------------------   arrived at 4\n    led_green.off()\n    led_red.on()\n    # -------------------------   Go to waypoint 5\n    prepare_for_turn_and_drive()\n    target = (-400.0, 750.0)\n    arrived = False\n    while not arrived:\n        controller.screen.clear_screen()\n        arrived = move_a_little_toward_loc(target, 1750, 300)\n        wait(5,MSEC)\n    # -------------------------  arrived at 5\n    controller.screen.set_cursor(4,1)\n    controller.screen.print(\"Done.\")\n    led_green.on()\n    led_yellow.on()\n    led_red.on()\n\ndef ondriver_drivercontrol_0():\n    global myVariable\n    brain.screen.clear_screen()\n    brain.screen.print(\"Start DC\")\n    while True:\n        wait(5, MSEC)\n\n# create a function for handling the starting and stopping of all autonomous tasks\ndef vexcode_auton_function():\n    # Start the autonomous control tasks\n    auton_task_0 = Thread( onauton_autonomous_0 )\n    # wait for the driver control period to end\n    while( competition.is_autonomous() and competition.is_enabled() ):\n        # wait 10 milliseconds before checking again\n        wait( 10, MSEC )\n    # Stop the autonomous control tasks\n    auton_task_0.stop()\n\ndef vexcode_driver_function():\n    # Start the driver control tasks\n    driver_control_task_0 = Thread( ondriver_drivercontrol_0 )\n\n    # wait for the driver control period to end\n    while( competition.is_driver_control() and competition.is_enabled() ):\n        # wait 10 milliseconds before checking again\n        wait( 10, MSEC )\n    # Stop the driver control tasks\n    driver_control_task_0.stop()\n\n\n# register the competition functions\ncompetition = Competition( vexcode_driver_function, vexcode_auton_function )\n\nwhen_started1()\n","textLanguage":"python","robotConfig":[{"port":[19,20],"name":"left_motors","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","gear":"ratio18_1","motor_a_reversed":"false","motor_b_reversed":"false"},"triportSourcePort":22},{"port":[9,10],"name":"right_motors","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","gear":"ratio18_1","motor_a_reversed":"true","motor_b_reversed":"true"},"triportSourcePort":22},{"port":[6],"name":"my_gps","customName":true,"deviceType":"GPS","deviceClass":"gps","setting":{"xOffset":"0","xOffsetUnit":"mm","yOffset":"40","yOffsetUnit":"mm","thetaOffset":"180"},"triportSourcePort":22},{"port":[1],"name":"led_green","customName":true,"deviceType":"LED","deviceClass":"led","setting":{},"triportSourcePort":22},{"port":[2],"name":"led_yellow","customName":true,"deviceType":"LED","deviceClass":"led","setting":{},"triportSourcePort":22},{"port":[3],"name":"led_red","customName":true,"deviceType":"LED","deviceClass":"led","setting":{},"triportSourcePort":22}],"slot":0,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.65.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"First","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"target":"Physical"}